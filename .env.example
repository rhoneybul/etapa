# Copy this file to .env and fill in your keys
# Restart the dev server after editing

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev: leave as http://localhost:3001
# Production: your Railway/Render URL e.g. https://etapa-api.railway.app
EXPO_PUBLIC_API_URL=http://localhost:3001

# ── Supabase (app-side, public keys only) ─────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Strava (optional — enables activity sync) ────────────────────────────────
# Create an app at: https://www.strava.com/settings/api
# Set the "Authorization Callback Domain" to: etapa://strava/callback
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=

# ── Anthropic API (optional — enables AI-generated plans) ───────────────────
# Get your key at: https://console.anthropic.com
# Without this key, plans are generated using the built-in local algorithm.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# ── RevenueCat (in-app purchases — iOS & Android) ──────────────────────────
# Public SDK key from RevenueCat dashboard → API Keys
EXPO_PUBLIC_REVENUECAT_API_KEY=

# ── Paywall bypass (dev only) ────────────────────────────────────────────────
# Set to true to skip the paywall during development
# EXPO_PUBLIC_PAYWALL_DISABLED=true
