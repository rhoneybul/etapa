# Supabase — get these from https://supabase.com → your project → Settings → API
# These are safe to expose publicly (they are anon/public keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Etapa API — the URL of your Etapa Express server
ETAPA_API_URL=http://localhost:3001
