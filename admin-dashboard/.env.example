# Google OAuth — get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32

# Etapa API — the URL of your Etapa Express server
ETAPA_API_URL=http://localhost:3001
# Shared secret to authenticate admin dashboard → Etapa server
# Generate with: openssl rand -base64 32
# Must match ADMIN_API_KEY in your Etapa server env
ADMIN_API_KEY=your-shared-admin-api-key
