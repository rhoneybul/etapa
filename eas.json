{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      },
      "ios": {
        "image": "sdk-55"
      }
    },
    "preview": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "preview",
      "ios": {
        "image": "sdk-55"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "image": "sdk-55"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761374058",
        "appleTeamId": "22Y4P5434A"
      }
    }
  }
}
