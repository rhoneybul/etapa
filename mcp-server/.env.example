# Etapa MCP — environment variables

# Port the MCP server listens on. Railway injects this automatically.
PORT=3002

# Base URL of the Etapa API. Default production URL shown below.
ETAPA_API_URL=https://etapa.up.railway.app

# Optional bearer token. If set, MCP clients must send
# `Authorization: Bearer <token>` on every /mcp request.
# Leave empty for a fully public MCP (fine — the underlying Etapa API
# endpoint is rate-limited and read-only).
MCP_AUTH_TOKEN=
