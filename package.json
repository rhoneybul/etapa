{
  "name": "etapa",
  "version": "0.1.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "npm run dev:server & npm run dev:app",
    "dev:app": "npx expo start",
    "dev:web": "npx expo start --web",
    "dev:server": "npm --prefix server run dev",
    "setup": "npm install && npm --prefix server install && cp -n server/.env.example server/.env 2>/dev/null; cp -n .env.example .env 2>/dev/null; echo '\\n✅ Setup done. Fill in server/.env and .env with your API keys.'",
    "release": "bash scripts/release.sh",
    "release:build": "bash scripts/release.sh build",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "test": "npm --prefix server test && node tests/rideSpeedRules.test.js && node tests/bikeSwap.test.js && node tests/workoutExport.test.js && node tests/exportSigning.test.js && node tests/checkinSafety.test.js && node tests/slack.test.js && node tests/rideTips.test.js",
    "test:api": "npm --prefix server test",
    "test:speed": "node tests/rideSpeedRules.test.js",
    "test:bike-swap": "node tests/bikeSwap.test.js",
    "test:workout-export": "node tests/workoutExport.test.js",
    "test:export-signing": "node tests/exportSigning.test.js",
    "test:checkin-safety": "node tests/checkinSafety.test.js",
    "test:slack": "node tests/slack.test.js",
    "test:tips": "node tests/rideTips.test.js",
    "test:plans": "node --import ./tests/loader.mjs tests/planGenerator.test.js",
    "test:e2e": "maestro test .maestro/",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/metro-runtime": "^55.0.6",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/stack": "^7.8.6",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~55.0.18",
    "expo-apple-authentication": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-file-system": "~55.0.13",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "~55.0.13",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-notifications": "~55.0.21",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "posthog-react-native": "^4.39.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^8.2.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sse": "^1.2.1",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/react": "~19.2.10",
    "babel-preset-expo": "^55.0.12",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-native-web": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    }
  }
}
