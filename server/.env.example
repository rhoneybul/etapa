# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

# Project URL (looks like https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# anon/public key — safe to expose, used to verify JWTs from the app
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — NEVER expose this in the app, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server config ─────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated origins allowed for CORS (leave * for local dev)
# Production: set to your Vercel URL e.g. https://etapa.vercel.app,https://admin-dashboard.vercel.app
ALLOWED_ORIGINS=*

# ── Admin dashboard ──────────────────────────────────────────────────────────
# Comma-separated emails that can access /api/admin/* endpoints
ADMIN_EMAILS=robert.honeybul@sylvera.io
# Shared secret for the admin dashboard to call /api/admin/* endpoints
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=your-shared-admin-api-key
