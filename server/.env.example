# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API

# Project URL (looks like https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# anon/public key — safe to expose, used to verify JWTs from the app
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role key — NEVER expose this in the app, server-only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server config ─────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated origins allowed for CORS (leave * for local dev)
# Production: set to your Vercel URL e.g. https://etapa.vercel.app,https://admin-dashboard.vercel.app
ALLOWED_ORIGINS=*

# ── Admin dashboard ──────────────────────────────────────────────────────────
# Comma-separated emails that can access /api/admin/* endpoints
ADMIN_EMAILS=robert.honeybul@sylvera.io
# Shared secret for the admin dashboard to call /api/admin/* endpoints
# Generate with: openssl rand -base64 32
ADMIN_API_KEY=your-shared-admin-api-key

# ── Workout export (Send-to-trainer) ─────────────────────────────────────────
# Server-side secret used to HMAC-sign one-shot workout-export URLs.
# Generate with: openssl rand -base64 48
# Must be at least 16 characters; rotate by changing this value (in-flight
# URLs will fail signature checks, which is fine — they're meant to be
# short-lived).
EXPORT_SIGNING_SECRET=replace-me-with-32-or-more-random-bytes
# Public base URL the signed export URL should point at. Defaults to the
# incoming request's host if unset, which is fine for dev. Set this
# explicitly in production so the URL points at the user-facing domain.
# Example: https://etapa-production.up.railway.app
EXPORT_BASE_URL=

# ── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_LIFETIME=price_...

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Webhook auth secret — set in RevenueCat dashboard → Integrations → Webhooks
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Secret API key — used by the admin dashboard to pull live transaction history
# per user (via /api/admin/users/:id/revenuecat). Generate in the RevenueCat
# dashboard → Project Settings → API keys → secret key. NEVER expose client-side.
REVENUECAT_SECRET_API_KEY=your-revenuecat-secret-api-key

# ── Marketing email unsubscribe ──────────────────────────────────────────────
# Server-only secret used to sign unsubscribe tokens. See server/MARKETING_EMAILS.md
# Generate with: openssl rand -base64 48
UNSUBSCRIBE_SECRET=replace-with-a-random-48-byte-secret

# Public URLs — used to build unsubscribe links in outgoing marketing emails.
PUBLIC_WEBSITE_URL=https://getetapa.com
PUBLIC_API_URL=https://etapa-production.up.railway.app

# MailerLite webhook signature. Set this in Railway AND in MailerLite
# (Integrations → Webhooks → your webhook → "Signature"). Keeps bad actors
# from spoofing unsubscribe events.
MAILERLITE_WEBHOOK_SECRET=replace-with-a-random-32-byte-token
