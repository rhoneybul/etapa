# Test Supabase project — NOT production!
# Create a separate Supabase project for testing, run the same migrations,
# then fill in these values.

SUPABASE_URL=https://your-test-project.supabase.co
SUPABASE_ANON_KEY=your-test-anon-key
SUPABASE_SERVICE_KEY=your-test-service-role-key

# Test user credentials — will be auto-created if they don't exist
TEST_USER_EMAIL=test@etapa.test
TEST_USER_PASSWORD=TestPassword123!

# Optional — leave blank to skip AI/Stripe tests
CLAUDE_API_KEY=
STRIPE_SECRET_KEY=
ADMIN_API_KEY=test-admin-key
CRON_SECRET=test-cron-secret
