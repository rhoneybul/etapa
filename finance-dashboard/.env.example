# ── Finance dashboard env vars ────────────────────────────────────────────
# Copy to .env.local for local dev. For Vercel, set the same keys in the
# project's Environment Variables UI.

# Supabase — the same project as the Etapa app. Client reads use the anon
# key; RLS on the finance schema does the actual gating.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Allowlist — comma-separated list of Google emails that may sign in.
# Duplicates finance.admin_allowlist in the DB; middleware checks this list
# as a fast rejection path, DB RLS checks the table as the belt-and-braces.
# Keep them in sync.
ALLOWED_EMAILS=honeybulr@gmail.com

# Optional: URL of the Express backend for webhook + job routes.
NEXT_PUBLIC_API_BASE_URL=https://etapa.up.railway.app
